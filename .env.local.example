# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# REQUIRED — lead form delivery. Every form on this site (Buy, Sell, Rent,
# popup, footer) POSTs to both of these simultaneously and independently
# of start.shivaluxury.com's webhooks.
NEXT_PUBLIC_SHEETS_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxxxx/xxxxxxx/
NEXT_PUBLIC_FUB_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxxxxx/xxxxxxx/

# OPTIONAL — powers the live homepage market-stats bar via Claude web search.
# Get from console.anthropic.com. If omitted, the stats bar falls back to a
# static, dated snapshot instead of a daily live pull.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — powers the "Watch and Learn" YouTube grid (latest 6 videos from
# the @shivaluxury channel). If omitted, the section falls back to a
# Subscribe-only card linking to the channel.
NEXT_PUBLIC_YOUTUBE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_YOUTUBE_CHANNEL_HANDLE=@shivaluxury

# OPTIONAL — powers live Google Reviews pull for the homepage trust section.
# Without these, the site shows the one verified review + aggregate rating
# captured manually, instead of fabricating the rest. Get a Places API key
# from console.cloud.google.com and find your Place ID at
# developers.google.com/maps/documentation/places/web-service/place-id
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_GOOGLE_PLACE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
